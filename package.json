{
  "name": "cinema-api",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "esbuild server.js --bundle --platform=node --target=node22 --packages=external --outfile=dist/index.js",
    "db:create": "node scripts/createDatabase.js",
    "db:migrate": "node scripts/runSequelizeCli.js db:migrate",
    "db:seed": "node scripts/runSequelizeCli.js db:seed:all",
    "db:setup": "node scripts/setupDatabase.js",
    "db:reset": "node scripts/setupDatabase.js --reset",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f mysql",
    "dev:setup": "npm run docker:up && npm run db:setup",
    "dev:full": "npm run dev:setup && npm run dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "mysql": "^2.18.1",
    "mysql2": "^3.15.2",
    "nodemailer": "^7.0.11",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.5",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "nodemon": "^3.1.10"
  }
}
